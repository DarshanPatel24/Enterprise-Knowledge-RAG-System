# EK-RAG Web UI — local environment template
# Copy to `.env.local` and fill values. Never commit `.env.local`.
# All client-visible values use the NEXT_PUBLIC_ prefix. Local-first: every
# value must point at a localhost service. No external hosts.

# Base URL of the EKCP API gateway (single entry point for all engine traffic).
# EKCP defaults to port 8003.
NEXT_PUBLIC_EKCP_API_URL=http://localhost:8003

# Tenant identifier injected as X-Tenant-ID on every request.
# Leave empty here; provide a real tenant id in .env.local.
# (Becomes user-configurable via the settings screen in UI-S3.)
NEXT_PUBLIC_EKCP_TENANT_ID=

# User identifier carried in the security context on governed requests.
# Leave empty here; provide a real user id in .env.local.
NEXT_PUBLIC_EKCP_USER_ID=

# Classification clearance carried in the security context.
# One of: public | internal | confidential | restricted. Defaults to public.
NEXT_PUBLIC_EKCP_CLEARANCE=public
