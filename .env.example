# Local-first development configuration template.
# Copy to .env and set real values locally. Never commit real secrets.

# Qdrant (vector DB)
QDRANT_PORT=6333

# Redis (cache)
REDIS_PORT=6379

# MinIO (object storage) - set strong local credentials
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Microsoft SQL Server (EK-RAG control plane) - local container only
# SA password must meet MS SQL complexity requirements.
MSSQL_PORT=1433
MSSQL_SA_PASSWORD=

# Langfuse internal PostgreSQL (observability tracing store ONLY - not an application database)
LANGFUSE_DB_USER=
LANGFUSE_DB_PASSWORD=
LANGFUSE_DB_NAME=langfuse

# Langfuse (self-hosted observability)
LANGFUSE_PORT=3000
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_NEXTAUTH_URL=http://localhost:3000