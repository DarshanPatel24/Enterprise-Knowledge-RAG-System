# EKCP environment configuration template (local-first defaults).
# Copy to `.env` and adjust. All values are configuration-driven; nothing is
# hardcoded in engine logic. Nested settings use the `__` delimiter.

# --- Top level ---
EKCP_APP_NAME=ekcp
EKCP_ENVIRONMENT=local

# --- API gateway (single entry point) ---
EKCP_GATEWAY__HOST=0.0.0.0
EKCP_GATEWAY__PORT=8003
# Comma-separated CORS origins for the web UI; blank disables cross-origin.
EKCP_GATEWAY__CORS_ALLOW_ORIGINS=
EKCP_GATEWAY__REQUEST_TIMEOUT_SECONDS=30.0

# --- Observability (structured logging + tracing) ---
EKCP_OBSERVABILITY__LOG_LEVEL=INFO
EKCP_OBSERVABILITY__SERVICE_NAME=ekcp
# Langfuse is self-hosted only; keep disabled for the fully offline path.
EKCP_OBSERVABILITY__LANGFUSE_ENABLED=false
EKCP_OBSERVABILITY__LANGFUSE_HOST=http://localhost:3000
EKCP_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKCP_OBSERVABILITY__LANGFUSE_SECRET_KEY=
# EKCP_OBSERVABILITY__OTEL_EXPORTER_ENDPOINT=

# --- Security context ingress ---
EKCP_SECURITY__REQUIRE_SECURITY_CONTEXT=true
EKCP_SECURITY__DEFAULT_CLEARANCE=public

# --- Redis cache/session backend (config-selected behind seams) ---
# Offline default keeps session and cache state in memory; enable for live Redis.
EKCP_REDIS__ENABLED=false
EKCP_REDIS__HOST=localhost
EKCP_REDIS__PORT=6379
EKCP_REDIS__DB=0
EKCP_REDIS__PASSWORD=
EKCP_REDIS__REQUEST_TIMEOUT_SECONDS=5.0

# --- Conversation control-plane persistence ---
# inmemory (offline default) or mssql (Microsoft SQL Server via URL).
EKCP_CONTROL_PLANE__DRIVER=inmemory
EKCP_CONTROL_PLANE__URL=
