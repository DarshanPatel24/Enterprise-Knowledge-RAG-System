# EKCP environment configuration template (local-first defaults).
# Copy to `.env` and adjust. All values are configuration-driven; nothing is
# hardcoded in engine logic. Nested settings use the `__` delimiter.

# --- Top level ---
EKCP_APP_NAME=ekcp
EKCP_ENVIRONMENT=local

# --- API gateway (single entry point) ---
EKCP_GATEWAY__HOST=0.0.0.0
EKCP_GATEWAY__PORT=8003
# Comma-separated CORS origins for the web UI; blank disables cross-origin.
# Origins must match the browser's Origin header EXACTLY (a mismatch makes the
# CORS preflight OPTIONS fail with 400), so list both localhost and 127.0.0.1
# forms. The web UI dev/start server runs on port 3001.
EKCP_GATEWAY__CORS_ALLOW_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
EKCP_GATEWAY__REQUEST_TIMEOUT_SECONDS=30.0

# --- Observability (structured logging + tracing) ---
EKCP_OBSERVABILITY__LOG_LEVEL=INFO
EKCP_OBSERVABILITY__SERVICE_NAME=ekcp
# Langfuse is self-hosted only; keep disabled for the fully offline path.
EKCP_OBSERVABILITY__LANGFUSE_ENABLED=false
EKCP_OBSERVABILITY__LANGFUSE_URL=http://localhost:3000
EKCP_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKCP_OBSERVABILITY__LANGFUSE_SECRET_KEY=
# EKCP_OBSERVABILITY__OTEL_EXPORTER_ENDPOINT=

# --- Security context ingress ---
EKCP_SECURITY__REQUIRE_SECURITY_CONTEXT=true
EKCP_SECURITY__DEFAULT_CLEARANCE=public
# Gateway authentication: when true, every governed request must present the
# shared token as `Authorization: Bearer <token>` or an `X-Service-Token` header,
# enforcing that only the trusted upstream gateway can reach EKCP. Enable and set
# a strong random token for any shared/production deployment.
EKCP_SECURITY__REQUIRE_GATEWAY_AUTH=false
EKCP_SECURITY__GATEWAY_AUTH_TOKEN=
# When false, client-supplied roles are ignored and only DEFAULT_ROLE applies so
# a caller cannot self-elevate; keep true only when the gateway derives roles
# from a verified token.
EKCP_SECURITY__TRUST_REQUEST_ROLES=true

# --- Redis cache/session backend (config-selected behind seams) ---
# Offline default keeps session and cache state in memory; enable for live Redis.
EKCP_REDIS__ENABLED=false
EKCP_REDIS__HOST=localhost
EKCP_REDIS__PORT=6379
EKCP_REDIS__DB=0
EKCP_REDIS__PASSWORD=
EKCP_REDIS__REQUEST_TIMEOUT_SECONDS=5.0

# --- Conversation control-plane persistence ---
# inmemory (offline default) or mssql (Microsoft SQL Server via URL).
EKCP_CONTROL_PLANE__DRIVER=inmemory
EKCP_CONTROL_PLANE__URL=

# --- Conversation lifecycle and Conversation Digital Twin ---
EKCP_CONVERSATION__DEFAULT_WORKSPACE_ID=default
EKCP_CONVERSATION__DEFAULT_LANGUAGE=en
EKCP_CONVERSATION__DEFAULT_PRIORITY=normal
EKCP_CONVERSATION__ARCHIVE_ON_COMPLETE=false
EKCP_CONVERSATION__ENABLE_EVENTS=true
# memory (append-only in-memory sink) or logging (structured log records).
EKCP_CONVERSATION__EVENT_SINK=memory

# --- Session and state management ---
EKCP_SESSION__SESSION_TTL_SECONDS=3600.0
EKCP_SESSION__MAX_CONCURRENT_SESSIONS=8

# --- Intent gating and confidence policy ---
# Below this confidence the gate requests clarification instead of executing.
EKCP_INTENT__CONFIDENCE_THRESHOLD=0.6
EKCP_INTENT__DEFAULT_LANGUAGE=en
EKCP_INTENT__ENABLE_LLM_INTENT=false

# --- Multi-turn dialog context (streaming chat) ---
# Deterministic history/follow-up/clarification handling per message. Fresh
# questions carry no history; follow-ups carry token-budgeted history and have
# their retrieval query rewritten from prior turns.
EKCP_DIALOG__HISTORY_MAX_TURNS=8
EKCP_DIALOG__HISTORY_TOKEN_BUDGET=600
EKCP_DIALOG__CHARS_PER_TOKEN=4
EKCP_DIALOG__TOPIC_OVERLAP_THRESHOLD=0.15
EKCP_DIALOG__CLARIFY_CONFIDENCE_THRESHOLD=0.35
EKCP_DIALOG__ENABLE_CLARIFICATION=true
EKCP_DIALOG__MAX_SEARCH_QUERY_CHARS=512
# Optional local-LLM follow-up condenser (off by default; deterministic fallback).
EKCP_DIALOG__ENABLE_LLM_CONDENSE=false
EKCP_DIALOG__CONDENSE_PROVIDER=huggingface
EKCP_DIALOG__CONDENSE_MODEL=
EKCP_DIALOG__CONDENSE_BASE_URL=http://localhost:11434
EKCP_DIALOG__CONDENSE_TEMPERATURE=0.0

# --- Context orchestration (assembly and budgeting) ---
EKCP_CONTEXT__MAX_CONTEXT_TOKENS=8000
EKCP_CONTEXT__CHARS_PER_TOKEN=4
EKCP_CONTEXT__MIN_RELEVANCE=0.0
EKCP_CONTEXT__DEDUPE_CONTENT=true
# Fraction of the context window reserved for generation headroom.
EKCP_CONTEXT__RESERVE_RATIO=0.1

# --- Prompt orchestration (construction and budgeting) ---
EKCP_PROMPT__DEFAULT_TEMPLATE_ID=enterprise_chat_v1
EKCP_PROMPT__MAX_PROMPT_TOKENS=12000
EKCP_PROMPT__CHARS_PER_TOKEN=4
# Assistant identity and behavior are configuration-driven, not hardcoded.
EKCP_PROMPT__ASSISTANT_IDENTITY=the enterprise knowledge assistant
EKCP_PROMPT__ASSISTANT_BEHAVIOR=Be accurate, concise, and policy-compliant.
EKCP_PROMPT__DEFAULT_OUTPUT_FORMAT=markdown

# --- Model management and LLM gateway ---
# runtime: deterministic (offline echo default) or langchain (real chat model).
EKCP_MODEL__RUNTIME=deterministic
# provider (when runtime=langchain): huggingface or ollama.
EKCP_MODEL__PROVIDER=huggingface
EKCP_MODEL__MODEL_NAME=
EKCP_MODEL__BASE_URL=http://localhost:11434
# Sampling controls. TEMPERATURE=0.0 is greedy/deterministic. To sample, raise
# TEMPERATURE (e.g. 0.2) and optionally set TOP_P (<1.0) and/or TOP_K (>0) to
# keep generation on the most relevant tokens. TOP_P/TOP_K are ignored at
# TEMPERATURE=0.
EKCP_MODEL__TEMPERATURE=0.0
EKCP_MODEL__TOP_P=1.0
EKCP_MODEL__TOP_K=0
# Execution device for the HuggingFace chat model. Blank = CPU. Set cuda / cuda:0
# / auto for GPU plus a dtype (float16/bfloat16) to save VRAM.
EKCP_MODEL__DEVICE=
EKCP_MODEL__TORCH_DTYPE=
EKCP_MODEL__CONTEXT_WINDOW=8192
EKCP_MODEL__MAX_OUTPUT_TOKENS=2048
EKCP_MODEL__PROMPT_COST_PER_1K=0.0
EKCP_MODEL__COMPLETION_COST_PER_1K=0.0
# routing_strategy: capability | cost | latency | quality | policy | hybrid.
EKCP_MODEL__ROUTING_STRATEGY=hybrid
# Blank auto-selects the deterministic model (or the configured chat model).
EKCP_MODEL__DEFAULT_MODEL_ID=
EKCP_MODEL__ENABLE_FALLBACK=true
EKCP_MODEL__REQUIRE_APPROVED=true
# Per-request governance ceilings (0 means unlimited).
EKCP_MODEL__MAX_TOKENS_PER_REQUEST=0
EKCP_MODEL__MAX_COST_PER_REQUEST=0.0
EKCP_MODEL__CHARS_PER_TOKEN=4

# --- Memory framework (tiers, retrieval, retention) ---
# Per-scope retention TTLs in seconds (0 = indefinite, used for organizational).
EKCP_MEMORY__WORKING_TTL_SECONDS=1800.0
EKCP_MEMORY__SESSION_TTL_SECONDS=28800.0
EKCP_MEMORY__CONVERSATION_TTL_SECONDS=2592000.0
EKCP_MEMORY__WORKSPACE_TTL_SECONDS=31536000.0
EKCP_MEMORY__USER_TTL_SECONDS=94608000.0
EKCP_MEMORY__ORGANIZATIONAL_TTL_SECONDS=0.0
EKCP_MEMORY__DEFAULT_MIN_CONFIDENCE=0.5
EKCP_MEMORY__DEFAULT_CLASSIFICATION=internal
EKCP_MEMORY__MAX_RETRIEVAL_LIMIT=10
# Retrieval ranking weights (relevance, recency, importance, frequency, trust).
EKCP_MEMORY__WEIGHT_RELEVANCE=0.4
EKCP_MEMORY__WEIGHT_RECENCY=0.2
EKCP_MEMORY__WEIGHT_IMPORTANCE=0.15
EKCP_MEMORY__WEIGHT_FREQUENCY=0.1
EKCP_MEMORY__WEIGHT_TRUST=0.15
EKCP_MEMORY__RECENCY_HALF_LIFE_HOURS=24.0

# --- Tool execution platform ---
EKCP_TOOLS__DEFAULT_TIMEOUT_SECONDS=10.0
EKCP_TOOLS__MAX_ATTEMPTS=2
# Enforce that callers hold every permission a tool requires before execution.
EKCP_TOOLS__ENFORCE_PERMISSIONS=true

# --- Agent runtime ---
# runner: sequential (offline default) or langgraph (graph + checkpointer).
EKCP_AGENT__RUNNER=sequential
# Bounded steps per agent execution to prevent runaway loops.
EKCP_AGENT__MAX_STEPS=4
EKCP_AGENT__BASE_CONFIDENCE=0.85

# --- Planning and orchestration ---
EKCP_PLANNING__MAX_TASKS=12
EKCP_PLANNING__DEFAULT_TASK_TIMEOUT_SECONDS=60.0

# --- Governance, security, and policy ---
EKCP_GOVERNANCE__ENFORCE_AUTHORIZATION=true
EKCP_GOVERNANCE__ENABLE_AUDIT=true
# audit_sink: memory (queryable, ephemeral) | logging | file (durable append-only).
# Use file for production compliance evidence that survives restarts.
EKCP_GOVERNANCE__AUDIT_SINK=memory
EKCP_GOVERNANCE__AUDIT_FILE_PATH=./storage/audit/ekcp_audit.jsonl
EKCP_GOVERNANCE__ENABLE_MASKING=true
EKCP_GOVERNANCE__MASK_EMAIL=true
EKCP_GOVERNANCE__MASK_PHONE=true
EKCP_GOVERNANCE__MASK_SSN=true
EKCP_GOVERNANCE__MASK_CREDIT_CARD=true
# Mask PII in inbound content (e.g. memory writes) before it is persisted.
EKCP_GOVERNANCE__MASK_INBOUND=true
EKCP_GOVERNANCE__ALLOW_CLASSIFICATION_DOWNGRADE=false
EKCP_GOVERNANCE__POLICY_VERSION=v1
# default_role: admin | power_user | user | service | agent.
EKCP_GOVERNANCE__DEFAULT_ROLE=power_user

# --- Enterprise knowledge integration (EKRE consumption) ---
# Disabled by default (offline); enable to fetch live knowledge from EKRE.
EKCP_KNOWLEDGE__ENABLED=false
EKCP_KNOWLEDGE__BASE_URL=http://localhost:8002
# Per-request HTTP timeout (seconds) for one EKRE retrieval. Must exceed a full
# live EKRE request (which includes EKRE's per-worker EKRE_EXECUTION__DEFAULT_TASK_TIMEOUT_MS
# budget plus rerank/assembly) so a slow-but-healthy call is not cut off.
EKCP_KNOWLEDGE__TIMEOUT_SECONDS=500.0
EKCP_KNOWLEDGE__MAX_RETRIES=3
EKCP_KNOWLEDGE__CIRCUIT_BREAKER_THRESHOLD=5
EKCP_KNOWLEDGE__CIRCUIT_BREAKER_RESET_SECONDS=60.0
# retrieval_mode: semantic | keyword | hybrid.
EKCP_KNOWLEDGE__RETRIEVAL_MODE=hybrid
EKCP_KNOWLEDGE__MAX_CANDIDATES=10
EKCP_KNOWLEDGE__RELEVANCE_THRESHOLD=0.5

# --- Workflow and event orchestration ---
EKCP_WORKFLOW__ENABLE_EVENTS=true
# event_bus: memory (queryable) or logging.
EKCP_WORKFLOW__EVENT_BUS=memory
EKCP_WORKFLOW__SOURCE_SERVICE=ekcp

# --- Deployment, multi-tenancy, and master handoff readiness ---
# Deployment topology and readiness gates. Container/cluster orchestration is
# out of scope (local-first); these tune the readiness a real deployment must meet.
EKCP_DEPLOYMENT__REPLICAS=2
EKCP_DEPLOYMENT__CIRCUIT_BREAKER_THRESHOLD=5
# Per-tenant concurrent request ceiling (0 disables admission control).
EKCP_DEPLOYMENT__TENANT_MAX_CONCURRENT=8
EKCP_DEPLOYMENT__TENANT_AWARE_OBSERVABILITY=true
# NFR targets validated at readiness time.
EKCP_DEPLOYMENT__FIRST_RESPONSE_LATENCY_BUDGET_MS=3000.0
EKCP_DEPLOYMENT__MIN_AVAILABILITY=0.999
# Master integration handoff KPI targets.
EKCP_DEPLOYMENT__MIN_CONVERSATION_COMPLETION=0.99
EKCP_DEPLOYMENT__MIN_TOOL_SUCCESS=0.99
EKCP_DEPLOYMENT__MIN_AGENT_ORCHESTRATION=0.99
EKCP_DEPLOYMENT__MIN_CONVERSATION_RECOVERY=1.0
EKCP_DEPLOYMENT__MIN_POLICY_COVERAGE=1.0
EKCP_DEPLOYMENT__MIN_AUDIT_COVERAGE=1.0
