# EKCP environment configuration template (local-first defaults).
# Copy to `.env` and adjust. All values are configuration-driven; nothing is
# hardcoded in engine logic. Nested settings use the `__` delimiter.

# --- Top level ---
EKCP_APP_NAME=ekcp
EKCP_ENVIRONMENT=local

# --- API gateway (single entry point) ---
EKCP_GATEWAY__HOST=0.0.0.0
EKCP_GATEWAY__PORT=8003
# Comma-separated CORS origins for the web UI; blank disables cross-origin.
EKCP_GATEWAY__CORS_ALLOW_ORIGINS=
EKCP_GATEWAY__REQUEST_TIMEOUT_SECONDS=30.0

# --- Observability (structured logging + tracing) ---
EKCP_OBSERVABILITY__LOG_LEVEL=INFO
EKCP_OBSERVABILITY__SERVICE_NAME=ekcp
# Langfuse is self-hosted only; keep disabled for the fully offline path.
EKCP_OBSERVABILITY__LANGFUSE_ENABLED=false
EKCP_OBSERVABILITY__LANGFUSE_HOST=http://localhost:3000
EKCP_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKCP_OBSERVABILITY__LANGFUSE_SECRET_KEY=
# EKCP_OBSERVABILITY__OTEL_EXPORTER_ENDPOINT=

# --- Security context ingress ---
EKCP_SECURITY__REQUIRE_SECURITY_CONTEXT=true
EKCP_SECURITY__DEFAULT_CLEARANCE=public

# --- Redis cache/session backend (config-selected behind seams) ---
# Offline default keeps session and cache state in memory; enable for live Redis.
EKCP_REDIS__ENABLED=false
EKCP_REDIS__HOST=localhost
EKCP_REDIS__PORT=6379
EKCP_REDIS__DB=0
EKCP_REDIS__PASSWORD=
EKCP_REDIS__REQUEST_TIMEOUT_SECONDS=5.0

# --- Conversation control-plane persistence ---
# inmemory (offline default) or mssql (Microsoft SQL Server via URL).
EKCP_CONTROL_PLANE__DRIVER=inmemory
EKCP_CONTROL_PLANE__URL=

# --- Conversation lifecycle and Conversation Digital Twin ---
EKCP_CONVERSATION__DEFAULT_WORKSPACE_ID=default
EKCP_CONVERSATION__DEFAULT_LANGUAGE=en
EKCP_CONVERSATION__DEFAULT_PRIORITY=normal
EKCP_CONVERSATION__ARCHIVE_ON_COMPLETE=false
EKCP_CONVERSATION__ENABLE_EVENTS=true
# memory (append-only in-memory sink) or logging (structured log records).
EKCP_CONVERSATION__EVENT_SINK=memory

# --- Session and state management ---
EKCP_SESSION__SESSION_TTL_SECONDS=3600.0
EKCP_SESSION__MAX_CONCURRENT_SESSIONS=8

# --- Intent gating and confidence policy ---
# Below this confidence the gate requests clarification instead of executing.
EKCP_INTENT__CONFIDENCE_THRESHOLD=0.6
EKCP_INTENT__DEFAULT_LANGUAGE=en
EKCP_INTENT__ENABLE_LLM_INTENT=false

# --- Context orchestration (assembly and budgeting) ---
EKCP_CONTEXT__MAX_CONTEXT_TOKENS=8000
EKCP_CONTEXT__CHARS_PER_TOKEN=4
EKCP_CONTEXT__MIN_RELEVANCE=0.0
EKCP_CONTEXT__DEDUPE_CONTENT=true
# Fraction of the context window reserved for generation headroom.
EKCP_CONTEXT__RESERVE_RATIO=0.1

# --- Prompt orchestration (construction and budgeting) ---
EKCP_PROMPT__DEFAULT_TEMPLATE_ID=enterprise_chat_v1
EKCP_PROMPT__MAX_PROMPT_TOKENS=12000
EKCP_PROMPT__CHARS_PER_TOKEN=4
# Assistant identity and behavior are configuration-driven, not hardcoded.
EKCP_PROMPT__ASSISTANT_IDENTITY=the enterprise knowledge assistant
EKCP_PROMPT__ASSISTANT_BEHAVIOR=Be accurate, concise, and policy-compliant.
EKCP_PROMPT__DEFAULT_OUTPUT_FORMAT=markdown
