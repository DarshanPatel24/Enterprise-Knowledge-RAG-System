# EKIE local-first configuration template.
# Copy to .env in services/ekie and set real values locally. Never commit secrets.
# All values are nested with the EKIE_ prefix and __ delimiter.

# --- Application ---
EKIE_APP_NAME=ekie
EKIE_ENVIRONMENT=local

# --- Control Plane (Microsoft SQL Server) ---
# Provide either component values below, or a full SQLAlchemy URL override.
# EKIE_CONTROL_PLANE__URL=mssql+pyodbc://sa:pass@localhost:1433/ekrag_control_plane?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes
EKIE_CONTROL_PLANE__HOST=localhost
EKIE_CONTROL_PLANE__PORT=1433
EKIE_CONTROL_PLANE__DATABASE=ekrag_control_plane
EKIE_CONTROL_PLANE__USER=sa
EKIE_CONTROL_PLANE__PASSWORD=
EKIE_CONTROL_PLANE__DRIVER=ODBC Driver 18 for SQL Server
EKIE_CONTROL_PLANE__ENCRYPT=true
EKIE_CONTROL_PLANE__TRUST_SERVER_CERTIFICATE=true

# --- Qdrant (vector DB) ---
EKIE_QDRANT__HOST=localhost
EKIE_QDRANT__PORT=6333

# --- Redis (cache) ---
EKIE_REDIS__HOST=localhost
EKIE_REDIS__PORT=6379

# --- Object storage (MinIO) ---
EKIE_STORAGE__ENDPOINT=localhost:9000
EKIE_STORAGE__ACCESS_KEY=
EKIE_STORAGE__SECRET_KEY=
EKIE_STORAGE__BUCKET=ekie-assets
EKIE_STORAGE__SECURE=false

# --- Observability ---
EKIE_OBSERVABILITY__LOG_LEVEL=INFO
EKIE_OBSERVABILITY__SERVICE_NAME=ekie
EKIE_OBSERVABILITY__LANGFUSE_ENABLED=false
EKIE_OBSERVABILITY__LANGFUSE_HOST=http://localhost:3000
EKIE_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKIE_OBSERVABILITY__LANGFUSE_SECRET_KEY=
# EKIE_OBSERVABILITY__OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# --- Repository Synchronization Policy ---
EKIE_SYNC__SCAN_STRATEGY=incremental
EKIE_SYNC__IGNORE_HIDDEN=true
EKIE_SYNC__IGNORE_TEMP=true
EKIE_SYNC__MAX_FILE_SIZE_BYTES=524288000
# Comma-separated allowlist; empty means all extensions are allowed.
EKIE_SYNC__ALLOWED_EXTENSIONS=
EKIE_SYNC__HASH_ALGORITHM=sha256
EKIE_SYNC__RENAME_DETECTION_ENABLED=true
EKIE_SYNC__DELETE_PROPAGATION_ENABLED=true
EKIE_SYNC__DEFAULT_CLASSIFICATION=internal

# --- Document Transformation Policy ---
EKIE_TRANSFORMATION__NORMALIZE_UNICODE=true
EKIE_TRANSFORMATION__COLLAPSE_BLANK_LINES=true
EKIE_TRANSFORMATION__INCLUDE_FRONT_MATTER=true
EKIE_TRANSFORMATION__DEFAULT_LANGUAGE=en
# reference | ignore_decorative | ocr
EKIE_TRANSFORMATION__IMAGE_HANDLING=reference
EKIE_TRANSFORMATION__OCR_ENABLED=false

# --- Document Intelligence Policy ---
EKIE_INTELLIGENCE__DETECT_LANGUAGE=true
EKIE_INTELLIGENCE__CLASSIFY_CONTENT=true
EKIE_INTELLIGENCE__DETECT_SENSITIVE_CONTENT=true
EKIE_INTELLIGENCE__DEFAULT_LANGUAGE=en
EKIE_INTELLIGENCE__HIGH_COMPLEXITY_SECTION_THRESHOLD=12

# --- Intelligent Chunking Policy ---
# semantic | section_based | heading_based | paragraph_based | token_based | table_based | code_based
EKIE_CHUNKING__DEFAULT_STRATEGY=semantic
EKIE_CHUNKING__TARGET_TOKEN_BUDGET=512
EKIE_CHUNKING__MAX_TOKEN_BUDGET=1024
EKIE_CHUNKING__MIN_CHUNK_TOKENS=8
EKIE_CHUNKING__PRESERVE_TABLES=true
EKIE_CHUNKING__PRESERVE_CODE=true
EKIE_CHUNKING__RESPECT_SECTION_BOUNDARIES=true
EKIE_CHUNKING__INCLUDE_BREADCRUMB_CONTEXT=true

# --- Embedding Framework Policy ---
# Local-first, deterministic, dependency-free hash embedding provider by default.
EKIE_EMBEDDING__DEFAULT_MODEL=local-hash-256
EKIE_EMBEDDING__PROVIDER=local
EKIE_EMBEDDING__DIMENSION=256
# cosine | dot_product | euclidean
EKIE_EMBEDDING__DISTANCE_METRIC=cosine
EKIE_EMBEDDING__MAX_INPUT_TOKENS=8192
EKIE_EMBEDDING__BATCH_SIZE=16
EKIE_EMBEDDING__NORMALIZE_VECTORS=true
EKIE_EMBEDDING__COST_PER_1K_TOKENS=0.0
EKIE_EMBEDDING__MAX_RETRIES=3
