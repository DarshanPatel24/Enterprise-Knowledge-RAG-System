# EKIE local-first configuration template.
# Copy to .env in services/ekie and set real values locally. Never commit secrets.
# All values are nested with the EKIE_ prefix and __ delimiter.

# --- Application ---
EKIE_APP_NAME=ekie
EKIE_ENVIRONMENT=local

# --- API gateway (server bind) ---
# Host/port the EKIE API binds to. 0.0.0.0 exposes it on all interfaces (same as
# EKRE/EKCP). Set 127.0.0.1 to restrict EKIE to localhost-only.
EKIE_GATEWAY__HOST=0.0.0.0
EKIE_GATEWAY__PORT=8001

# --- Control Plane (Microsoft SQL Server) ---
# Provide component values below, or a full SQLAlchemy URL via EKIE_CONTROL_PLANE__URL.
EKIE_CONTROL_PLANE__HOST=localhost
EKIE_CONTROL_PLANE__PORT=1433
EKIE_CONTROL_PLANE__DATABASE=ekrag_control_plane
EKIE_CONTROL_PLANE__USER=sa
EKIE_CONTROL_PLANE__PASSWORD=
# Set EKIE_CONTROL_PLANE__TRUSTED_CONNECTION=false to true to use Windows Authentication (ignores USER and PASSWORD)
EKIE_CONTROL_PLANE__TRUSTED_CONNECTION=false
EKIE_CONTROL_PLANE__DRIVER=ODBC Driver 18 for SQL Server
EKIE_CONTROL_PLANE__ENCRYPT=true
EKIE_CONTROL_PLANE__TRUST_SERVER_CERTIFICATE=true

# --- Qdrant (vector DB) ---
EKIE_QDRANT__HOST=localhost
EKIE_QDRANT__PORT=6333
# Optional: a full Qdrant URL and API key (used by the LangChain index template).
# Leave blank to connect via HOST/PORT above.
EKIE_QDRANT__URL=
EKIE_QDRANT__API_KEY=
EKIE_QDRANT__REQUEST_TIMEOUT_SECONDS=30.0

# --- Redis (cache) ---
EKIE_REDIS__HOST=localhost
EKIE_REDIS__PORT=6379

# --- Object storage (MinIO) ---
# In the default local environment, assets are persisted to disk at
# EKIE_STORAGE__LOCAL_PATH (below) and the MinIO settings are ignored. MinIO is
# used only when EKIE_ENVIRONMENT is not "local" and ENDPOINT is set.
EKIE_STORAGE__ENDPOINT=localhost:9005
EKIE_STORAGE__ACCESS_KEY=
EKIE_STORAGE__SECRET_KEY=
EKIE_STORAGE__BUCKET=ekie-assets
EKIE_STORAGE__SECURE=false
# Local-first persistent asset directory (relative to the service working dir).
# Stage payloads (markdown, chunks, embeddings, vectors) are written here so
# they survive API/worker restarts.
EKIE_STORAGE__LOCAL_PATH=storage/assets

# --- Observability ---
EKIE_OBSERVABILITY__LOG_LEVEL=INFO
EKIE_OBSERVABILITY__SERVICE_NAME=ekie
EKIE_OBSERVABILITY__LANGFUSE_ENABLED=false
EKIE_OBSERVABILITY__LANGFUSE_URL=http://localhost:3000
EKIE_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKIE_OBSERVABILITY__LANGFUSE_SECRET_KEY=
# EKIE_OBSERVABILITY__OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# --- Repository Synchronization Policy ---
EKIE_SYNC__SCAN_STRATEGY=incremental
EKIE_SYNC__IGNORE_HIDDEN=true
EKIE_SYNC__IGNORE_TEMP=true
EKIE_SYNC__MAX_FILE_SIZE_BYTES=524288000
# Comma-separated allowlist; empty means all extensions are allowed.
# EKIE ingests Markdown produced upstream by the EKDC converter, so restrict to .md.
EKIE_SYNC__ALLOWED_EXTENSIONS=md
EKIE_SYNC__HASH_ALGORITHM=sha256
EKIE_SYNC__RENAME_DETECTION_ENABLED=true
EKIE_SYNC__DELETE_PROPAGATION_ENABLED=true
EKIE_SYNC__DEFAULT_CLASSIFICATION=internal

# Built-in Production Worker settings
# Point TARGET_DIRECTORY at the EKDC OUTPUT_DIRECTORY (the folder of generated .md files).
EKIE_SYNC__TARGET_DIRECTORY=
EKIE_SYNC__TENANT_ID=tenant-default
EKIE_SYNC__POLL_INTERVAL_SECONDS=300
EKIE_SYNC__API_BASE_URL=http://localhost:8005
# Worker HTTP timeouts. Ingestion runs the full pipeline (transform → intelligence →
# chunking → embedding → publish) synchronously, so large documents need a generous
# read timeout. Increase this if big files still time out.
EKIE_SYNC__INGEST_TIMEOUT_SECONDS=1800
EKIE_SYNC__DELETE_TIMEOUT_SECONDS=120

# --- Document Transformation Policy ---
# EKIE ingests Markdown produced by EKDC; format conversion (PDF/DOCX/PPTX/HTML/CSV/
# images/audio/video) is owned by the EKDC agent, not this engine.
EKIE_TRANSFORMATION__NORMALIZE_UNICODE=true
EKIE_TRANSFORMATION__COLLAPSE_BLANK_LINES=true
EKIE_TRANSFORMATION__INCLUDE_FRONT_MATTER=true
EKIE_TRANSFORMATION__DEFAULT_LANGUAGE=en

# --- Document Intelligence Policy ---
EKIE_INTELLIGENCE__DETECT_LANGUAGE=true
EKIE_INTELLIGENCE__CLASSIFY_CONTENT=true
EKIE_INTELLIGENCE__DETECT_SENSITIVE_CONTENT=true
EKIE_INTELLIGENCE__DEFAULT_LANGUAGE=en
EKIE_INTELLIGENCE__HIGH_COMPLEXITY_SECTION_THRESHOLD=12
# Optional LLM-based topic analysis (off by default; heuristics stay the default).
# Requires langchain-ollama and a running Ollama model (for example llama3.1).
# To download and run HuggingFace models locally (e.g., Qwen/Qwen2.5-3B-Instruct):
# 1. pip install langchain-huggingface torch transformers accelerate
# 2. Set EKIE_INTELLIGENCE__ENABLE_LLM_ANALYSIS=true
# 3. Set EKIE_INTELLIGENCE__LLM_PROVIDER=huggingface/ollama
# 4. Set EKIE_INTELLIGENCE__LLM_MODEL to your HF model (e.g., Qwen/Qwen2.5-3B-Instruct)
EKIE_INTELLIGENCE__ENABLE_LLM_ANALYSIS=false
EKIE_INTELLIGENCE__LLM_PROVIDER=ollama
EKIE_INTELLIGENCE__LLM_MODEL=llama3.1
EKIE_INTELLIGENCE__LLM_BASE_URL=http://localhost:11434
EKIE_INTELLIGENCE__LLM_TEMPERATURE=0.0
EKIE_INTELLIGENCE__LLM_REQUEST_TIMEOUT_SECONDS=60.0

# --- Intelligent Chunking Policy ---
# semantic | section_based | heading_based | paragraph_based | token_based | table_based | code_based | recursive
EKIE_CHUNKING__DEFAULT_STRATEGY=semantic
EKIE_CHUNKING__TARGET_TOKEN_BUDGET=512
EKIE_CHUNKING__MAX_TOKEN_BUDGET=1024
EKIE_CHUNKING__MIN_CHUNK_TOKENS=8
EKIE_CHUNKING__PRESERVE_TABLES=true
EKIE_CHUNKING__PRESERVE_CODE=true
EKIE_CHUNKING__RESPECT_SECTION_BOUNDARIES=true
EKIE_CHUNKING__INCLUDE_BREADCRUMB_CONTEXT=true
# Recursive character chunking (opt-in). Only used when DEFAULT_STRATEGY=recursive.
# Requires: pip install langchain-text-splitters
EKIE_CHUNKING__RECURSIVE_CHUNK_SIZE=1000
EKIE_CHUNKING__RECURSIVE_CHUNK_OVERLAP=200

# --- Embedding Framework Policy ---
# Local-first, deterministic, dependency-free hash embedding provider by default.
# To use local HuggingFace models without Ollama:
# 1. pip install langchain-huggingface sentence-transformers
# 2. Set EKIE_EMBEDDING__PROVIDER=huggingface
# 3. Set EKIE_EMBEDDING__DEFAULT_MODEL to your HF model (e.g., BAAI/bge-base-en-v1.5)
# 4. Set EKIE_EMBEDDING__DIMENSION to match your model's output dimension (e.g., 768 for bge-base).
# 5. Set HF_HOME to a local directory to persistently cache model weights.
HF_HOME=./.hf_cache
EKIE_EMBEDDING__DEFAULT_MODEL=local-hash-256
EKIE_EMBEDDING__PROVIDER=local
EKIE_EMBEDDING__DIMENSION=256
# cosine | dot_product | euclidean
EKIE_EMBEDDING__DISTANCE_METRIC=cosine
EKIE_EMBEDDING__MAX_INPUT_TOKENS=8192
# Chunks per embedding request. Raise (e.g. 32-64) for higher throughput on
# large document sets; it does not change the resulting vectors.
EKIE_EMBEDDING__BATCH_SIZE=16
EKIE_EMBEDDING__NORMALIZE_VECTORS=true
EKIE_EMBEDDING__COST_PER_1K_TOKENS=0.0
EKIE_EMBEDDING__MAX_RETRIES=3
# Optional throughput cap: max embedding requests per minute (0 = unlimited).
# Only needed to respect a throttled/hosted embedding API; leave 0 for local.
EKIE_EMBEDDING__MAX_REQUESTS_PER_MINUTE=0
# Oversized-chunk handling. true (default): clip a chunk's text to MAX_INPUT_TOKENS
# to fit the model window (emits an EmbeddingTruncated warning) so a large document
# never dead-letters. false: fail hard with token_limit_exceeded instead -- only do
# this if you have sized chunks (TARGET/MAX budgets or DEFAULT_STRATEGY=recursive)
# so no chunk can exceed the window.
EKIE_EMBEDDING__TRUNCATE_OVERSIZED_CHUNKS=false
# Real embeddings via a local Ollama model. To enable, set PROVIDER=ollama,
# DEFAULT_MODEL to a pulled model (for example nomic-embed-text), and DIMENSION
# to that model's output size (nomic-embed-text=768, mxbai-embed-large=1024).
EKIE_EMBEDDING__OLLAMA_BASE_URL=http://localhost:11434
EKIE_EMBEDDING__REQUEST_TIMEOUT_SECONDS=60.0
# GPU acceleration for the HuggingFace embedding provider (requires a CUDA build
# of PyTorch: pip install torch --index-url https://download.pytorch.org/whl/cu130).
# DEVICE: "auto" (GPU when available) | "cuda" | "cpu".
# TORCH_DTYPE: "auto" (fp32) | "float16" | "bfloat16". Use float16 to halve VRAM so
# models fit smaller GPUs (bge-base uses ~250MB in fp16).
EKIE_EMBEDDING__DEVICE=auto
EKIE_EMBEDDING__TORCH_DTYPE=auto

# --- Vector Publishing Policy ---
# Local-first, in-process vector provider by default. Collection names come from
# policy, never hardcoded in code.
EKIE_PUBLISHING__PROVIDER=local
EKIE_PUBLISHING__DEFAULT_COLLECTION=enterprise_documents
# Vectors per upsert to the vector DB. Raise (e.g. 128-256) for faster ingest.
EKIE_PUBLISHING__BATCH_SIZE=64
EKIE_PUBLISHING__MAX_RETRIES=3
# Optional throughput cap: max vectors upserted per minute (0 = unlimited).
EKIE_PUBLISHING__MAX_VECTORS_PER_MINUTE=0
EKIE_PUBLISHING__CREATE_MISSING_COLLECTIONS=true
EKIE_PUBLISHING__VERIFY_AFTER_PUBLISH=true
# static | model_scoped (model_scoped appends provider/model/dimension suffix) 
EKIE_PUBLISHING__COLLECTION_STRATEGY=static 
# Real vector database via self-hosted Qdrant. To enable, set PROVIDER=qdrant;
# the connection is configured under the canonical EKIE_QDRANT__ settings above.

# --- Workflow orchestration (EKIE-S7) ---
# Runner selects the ingestion graph engine. "sequential" is the offline default;
# "langgraph" builds a LangGraph StateGraph and requires the langgraph package.
EKIE_ORCHESTRATION__RUNNER=sequential
# Per-stage retry budget before a workflow is dead-lettered.
EKIE_ORCHESTRATION__MAX_ATTEMPTS_PER_STAGE=3
# Exponential backoff between stage retries (0 disables sleeping).
EKIE_ORCHESTRATION__RETRY_BACKOFF_BASE_SECONDS=0.0
EKIE_ORCHESTRATION__RETRY_BACKOFF_MULTIPLIER=2.0
# Emit Langfuse traces from the LangGraph runner (self-hosted; see EKIE_OBSERVABILITY__).
EKIE_ORCHESTRATION__ENABLE_TRACING=false

# --- Durable ingestion job queue ---
# When async is enabled the ingestion API enqueues a durable job and returns
# immediately (HTTP 202); a separate worker pool (scripts/start_ingest_worker.py)
# executes the pipeline. This decouples request latency from pipeline duration so
# large documents no longer exhaust HTTP read timeouts. Set to false to run the
# pipeline inline within the request (legacy blocking behavior).
# NOTE: enabling this requires running the ingest worker (scripts/start_ingest_worker.py);
# otherwise jobs will queue but never execute.
EKIE_INGESTION__ASYNC_ENABLED=false
# Number of concurrent worker processes to run per start_ingest_worker invocation.
EKIE_INGESTION__WORKER_CONCURRENCY=1
# How many jobs a worker claims per poll, and how often it polls when idle.
EKIE_INGESTION__CLAIM_BATCH_SIZE=1
EKIE_INGESTION__POLL_INTERVAL_SECONDS=2.0
# Whole-job retry budget before a job is moved to dead_letter.
EKIE_INGESTION__MAX_ATTEMPTS=3
# Exponential backoff between job retries, capped at the max.
EKIE_INGESTION__RETRY_BACKOFF_BASE_SECONDS=30.0
EKIE_INGESTION__RETRY_BACKOFF_MULTIPLIER=2.0
EKIE_INGESTION__RETRY_BACKOFF_MAX_SECONDS=900.0
# A running worker refreshes its job lock on this interval so a live worker is
# never mistaken for a crashed one, even during long stages (embedding, etc.).
# Keep it well below VISIBILITY_TIMEOUT_SECONDS (a few times smaller).
EKIE_INGESTION__HEARTBEAT_INTERVAL_SECONDS=15.0
# A claimed job whose lock has not been refreshed within this window is treated
# as orphaned and reclaimed for resume (covers hard worker crashes / closed
# windows). Because a live worker heartbeats, this bounds hard-kill recovery
# time -- a restarted worker resumes the in-progress document within roughly
# this many seconds instead of waiting minutes. Graceful Ctrl+C releases the job
# immediately. For multi-worker pools, keep it a comfortable multiple of the
# heartbeat interval.
EKIE_INGESTION__VISIBILITY_TIMEOUT_SECONDS=90.0

# --- Security and authorization (EKIE-S8) ---
# Require an authenticated principal on ingestion requests. Local-first default
# is false, which authenticates a configured anonymous service principal.
EKIE_SECURITY__REQUIRE_AUTHENTICATION=false
# Enforce RBAC + ABAC authorization decisions (per-stage policy enforcement).
EKIE_SECURITY__ENFORCE_AUTHORIZATION=true
# Role and clearance granted to the anonymous principal when auth is disabled.
EKIE_SECURITY__ANONYMOUS_ROLE=service_worker
EKIE_SECURITY__ANONYMOUS_CLEARANCE=restricted
# Lowest classification a resource may carry.
EKIE_SECURITY__MINIMUM_CLEARANCE=public

# --- Governance and audit (EKIE-S8) ---
# Emit an append-only audit record for every governed action.
EKIE_GOVERNANCE__ENABLE_AUDIT=true
# Audit destination: "logging" (structured JSON logs) or "memory" (in-process).
EKIE_GOVERNANCE__AUDIT_SINK=logging
# Permit classification downgrade during propagation (disabled by default).
EKIE_GOVERNANCE__ALLOW_CLASSIFICATION_DOWNGRADE=false

# --- Plugin SDK and sandbox validation (EKIE-S8) ---
# Require a manifest signature before a plugin can activate.
EKIE_PLUGINS__REQUIRE_SIGNATURE=true
# Permit unsigned plugins (development only; leave false in production).
EKIE_PLUGINS__ALLOW_UNSIGNED=false
# Comma-separated trusted publisher identities (empty allows any signed author).
EKIE_PLUGINS__TRUSTED_PUBLISHERS=
# Host EKIE version used for semantic-version compatibility checks.
EKIE_PLUGINS__EKIE_VERSION=1.0.0
# Sandbox execution timeout budget in seconds.
EKIE_PLUGINS__SANDBOX_TIMEOUT_SECONDS=5.0

# --- Deployment, NFR, and disaster-recovery targets (EKIE-S9) ---
# Minimum acceptable pipeline success rate (0-1) for readiness.
EKIE_DEPLOYMENT__MIN_SUCCESS_RATE=0.99
# Maximum acceptable p95 per-document latency budget in seconds.
EKIE_DEPLOYMENT__MAX_STAGE_LATENCY_SECONDS=5.0
# Recovery Point Objective in seconds (maximum tolerable data loss window).
EKIE_DEPLOYMENT__RPO_SECONDS=300.0
# Recovery Time Objective in seconds (maximum tolerable restoration time).
EKIE_DEPLOYMENT__RTO_SECONDS=900.0
# Desired replica count; >=2 recommended for high availability outside local.
EKIE_DEPLOYMENT__REPLICAS=1


