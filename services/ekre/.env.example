# EKRE (Enterprise Knowledge Retrieval Engine) - example environment file.
#
# Configuration over code: every operational value lives here and is wired into
# the service through the settings module. No credentials, endpoints, models, or
# limits are hardcoded. Copy to `.env` and adjust for your environment.
#
# IMPORTANT (sameness rule): EKRE must query the SAME Qdrant collection with the
# SAME embedding model and distance metric that EKIE used to create the stored
# vectors. The embedding model, dimension, and distance metric are INHERITED
# from the collection at runtime; the values below are documented FALLBACKS only.

# --- Application ---
EKRE_APP_NAME=ekre
EKRE_ENVIRONMENT=local

# --- API gateway (server bind) ---
# Host/port the EKRE API binds to. 0.0.0.0 exposes it on all interfaces (same as
# EKIE/EKCP). Set 127.0.0.1 to restrict EKRE to localhost-only (internal use).
EKRE_GATEWAY__HOST=0.0.0.0
EKRE_GATEWAY__PORT=8002

# --- Qdrant vector database (shared with EKIE) ---
EKRE_QDRANT__HOST=localhost
EKRE_QDRANT__PORT=6333
# Optional full URL + API key; when blank the host/port above are used.
EKRE_QDRANT__URL=
EKRE_QDRANT__API_KEY=
EKRE_QDRANT__REQUEST_TIMEOUT_SECONDS=30.0
# Payload key under which EKIE nests governance metadata (tenant_id,
# classification_clearance, document_id, ...). Set to "" for top-level fields.
EKRE_QDRANT__PAYLOAD_METADATA_KEY=metadata

# --- Observability (structured JSON logs + Langfuse tracing) ---
EKRE_OBSERVABILITY__LOG_LEVEL=INFO
EKRE_OBSERVABILITY__SERVICE_NAME=ekre
EKRE_OBSERVABILITY__LANGFUSE_ENABLED=false
EKRE_OBSERVABILITY__LANGFUSE_URL=http://localhost:3000
EKRE_OBSERVABILITY__LANGFUSE_PUBLIC_KEY=
EKRE_OBSERVABILITY__LANGFUSE_SECRET_KEY=

# --- Retrieval behavior and profiles ---
# The collection EKIE published vectors into (source of the inherited profile).
EKRE_RETRIEVAL__DEFAULT_COLLECTION=enterprise_documents
# Optional comma-separated allowlist of collections a client may target. Empty
# permits any; the default collection is always allowed.
EKRE_RETRIEVAL__ALLOWED_COLLECTIONS=
EKRE_RETRIEVAL__SEARCH_TYPE=similarity
EKRE_RETRIEVAL__DEFAULT_TOP_K=5
# Stage latency budgets in milliseconds (handbook NFR targets).
# These are SLO targets for the stage-timeline report only; they do NOT cap
# execution. The hard per-task kill-timeout is EKRE_EXECUTION__DEFAULT_TASK_TIMEOUT_MS.
EKRE_RETRIEVAL__BUDGET_QUERY_UNDERSTANDING_MS=20.0
EKRE_RETRIEVAL__BUDGET_VECTOR_MS=150.0
EKRE_RETRIEVAL__BUDGET_RANKING_MS=100.0
EKRE_RETRIEVAL__BUDGET_ASSEMBLY_MS=50.0
EKRE_RETRIEVAL__BUDGET_TOTAL_MS=500.0

# --- Query embedding runtime ---
# PROVIDER selects HOW the query is embedded (which library loads the model).
# It must be able to load the SAME model EKIE used (default: HuggingFace, e.g.
# a Qwen embedding model). The MODEL/DIMENSION/METRIC below are fallbacks only;
# the resolver inherits them from the collection. Switch PROVIDER to "ollama"
# to load the same model through the Ollama runtime instead.
EKRE_EMBEDDING__PROVIDER=huggingface
EKRE_EMBEDDING__FALLBACK_MODEL=
EKRE_EMBEDDING__BASE_URL=http://localhost:11434
EKRE_EMBEDDING__REQUEST_TIMEOUT_SECONDS=60.0
EKRE_EMBEDDING__NORMALIZE_VECTORS=true
# HuggingFace provider device/precision ("auto" keeps library defaults).
EKRE_EMBEDDING__DEVICE=auto
EKRE_EMBEDDING__TORCH_DTYPE=auto

# --- Inheritance of embedding + distance settings from EKIE metadata ---
# When false, only inherited values are used and unresolved settings raise; when
# true, the fallbacks below may substitute a missing inherited value.
EKRE_INHERITANCE__ALLOW_CONFIG_FALLBACK=true
EKRE_INHERITANCE__FALLBACK_EMBEDDING_MODEL=
EKRE_INHERITANCE__FALLBACK_DIMENSION=0
EKRE_INHERITANCE__FALLBACK_DISTANCE_METRIC=cosine

# --- Security context ingress ---
# When true, every retrieval request must carry a valid security context.
EKRE_SECURITY__REQUIRE_SECURITY_CONTEXT=true
# When true, retrieval is scoped to the requesting tenant at the repository
# boundary and re-checked in-process (tenant isolation, defense in depth).
EKRE_SECURITY__REQUIRE_TENANT_SCOPE=true
EKRE_SECURITY__DEFAULT_CLEARANCE=public
# Verifiable trust boundary: when true, the security context must arrive as a
# signed JWT in the X-Security-Context header (minted by the trusted caller,
# EKCP), instead of being self-asserted in the request body. Enable once the
# caller signs contexts. HS256/384/512 (shared secret); iss/aud checked when set.
EKRE_SECURITY__REQUIRE_SIGNED_CONTEXT=false
EKRE_SECURITY__CONTEXT_SIGNING_SECRET=
EKRE_SECURITY__CONTEXT_SIGNING_ALGORITHM=HS256
EKRE_SECURITY__CONTEXT_ISSUER=
EKRE_SECURITY__CONTEXT_AUDIENCE=
EKRE_SECURITY__CONTEXT_LEEWAY_SECONDS=30

# --- Query intelligence (understanding, intent, enrichment, planning) ---
EKRE_QUERY__MAX_QUERY_LENGTH=2048
EKRE_QUERY__DEFAULT_LANGUAGE=en
# Candidate counts selected per retrieval profile.
EKRE_QUERY__CANDIDATE_COUNT_PRECISION=5
EKRE_QUERY__CANDIDATE_COUNT_RECALL=50
EKRE_QUERY__CANDIDATE_COUNT_BALANCED=20
EKRE_QUERY__CANDIDATE_COUNT_COMPLIANCE=30
EKRE_QUERY__CANDIDATE_COUNT_PERFORMANCE=10
# Optional LangChain LLM query interpreter. Deterministic rules are the default
# and the fallback; enabling this never changes the deterministic contract.
# PROVIDER is dynamic (huggingface or ollama); set MODEL for your use case.
EKRE_QUERY__ENABLE_LLM_INTERPRETER=false
EKRE_QUERY__LLM_PROVIDER=huggingface
EKRE_QUERY__LLM_MODEL=
EKRE_QUERY__LLM_BASE_URL=http://localhost:11434
EKRE_QUERY__LLM_TEMPERATURE=0.0
EKRE_QUERY__LLM_REQUEST_TIMEOUT_SECONDS=60.0

# --- Retrieval execution core (orchestration, scheduling, workers) ---
# Runner: "concurrent" (deterministic default) or "langgraph" (optional graph runtime).
EKRE_EXECUTION__RUNNER=concurrent
EKRE_EXECUTION__MAX_PARALLEL_WORKERS=4
# Hard per-task execution deadline in milliseconds: the runner kills a worker
# future that exceeds it. This is the wall-clock budget for ONE live worker call
# (embedding inference + a vector/keyword query over the network), not the
# EKRE_RETRIEVAL__BUDGET_* latency SLO targets. A single query embedding on a
# shared/contended GPU can take well over ten seconds; if the worker is killed
# mid-call its completed result is discarded, so keep this above real embedding
# latency. The deterministic in-memory path finishes far inside it.
EKRE_EXECUTION__DEFAULT_TASK_TIMEOUT_MS=30000.0
EKRE_EXECUTION__MAX_ATTEMPTS_PER_TASK=1
EKRE_EXECUTION__ADMISSION_ENABLED=true
# fail_open=true: an all-worker failure returns an empty result instead of raising.
EKRE_EXECUTION__FAIL_OPEN=true
EKRE_EXECUTION__ENABLE_TRACING=false

# --- Retrieval workers + repository connector ---
# CONNECTOR: "inmemory" (local-first, offline default) or "qdrant" (live vector store).
EKRE_WORKERS__CONNECTOR=inmemory
# QUERY_EMBEDDER: "local_hash" (deterministic, offline) or "langchain" (inherited EKIE model).
EKRE_WORKERS__QUERY_EMBEDDER=local_hash
# Dimension for the local hash embedder (offline path only; qdrant uses the inherited dimension).
EKRE_WORKERS__LOCAL_EMBEDDING_DIMENSION=256

# --- Candidate collection + fusion ---
# IDENTITY_POLICY: "chunk" (document+chunk), "document" (per document), or "strict" (document+chunk+source).
EKRE_FUSION__IDENTITY_POLICY=chunk
# Reciprocal Rank Fusion constant (higher = flatter rank weighting).
EKRE_FUSION__RRF_K=60

# --- Ranking engine (evidence-weighted, auditable, deterministic) ---
EKRE_RANKING__CANDIDATE_LIMIT=10
EKRE_RANKING__MIN_COMPOSITE_SCORE=0.0
# Evidence factor weights (configurable, versioned via POLICY_VERSION).
EKRE_RANKING__SEMANTIC_WEIGHT=0.4
EKRE_RANKING__LEXICAL_WEIGHT=0.2
EKRE_RANKING__METADATA_WEIGHT=0.1
EKRE_RANKING__FUSION_WEIGHT=0.3
EKRE_RANKING__POLICY_VERSION=v1
# Cross-encoder reranker (handbook Ch.25.11): a purpose-built reranker model
# such as BAAI/bge-reranker-base scores query/document relevance and reorders
# the top candidates (no chat generation — that is EKCP). Disabled by default and
# degrades to the deterministic order when unavailable. Run it on CPU
# (RERANKER_DEVICE=cpu) so the EKCP chat LLM keeps the full 6 GB GPU.
EKRE_RANKING__ENABLE_RERANKER=false
EKRE_RANKING__RERANKER_MODEL=
EKRE_RANKING__RERANKER_DEVICE=auto
EKRE_RANKING__RERANKER_TORCH_DTYPE=auto
EKRE_RANKING__RERANKER_TRUST_REMOTE_CODE=false

# --- Context assembly + response packaging (final EKRE -> EKCP handoff) ---
EKRE_ASSEMBLY__MAX_CONTEXT_TOKENS=4000
EKRE_ASSEMBLY__MAX_OBJECTS=10
# Reading order: "rank" (relevance) or "document" (grouped by document/chunk).
EKRE_ASSEMBLY__ORDERING=rank
EKRE_ASSEMBLY__NORMALIZE_WHITESPACE=true
EKRE_ASSEMBLY__DEDUPE_CONTENT=true
# Rough token estimate: characters per token.
EKRE_ASSEMBLY__CHARS_PER_TOKEN=4
EKRE_ASSEMBLY__MIN_RELEVANCE=0.0

# --- Observability, security audit, and compliance (cross-cutting) ---
EKRE_GOVERNANCE__ENABLE_AUDIT=true
# audit sink: "logging" (structured logs) or "memory" (in-process, for tests).
EKRE_GOVERNANCE__AUDIT_SINK=logging
# Mask PII in the handoff package so no sensitive content reaches EKCP.
EKRE_GOVERNANCE__ENABLE_MASKING=true
EKRE_GOVERNANCE__MASK_EMAIL=true
EKRE_GOVERNANCE__MASK_PHONE=true
EKRE_GOVERNANCE__MASK_SSN=true
EKRE_GOVERNANCE__MASK_CREDIT_CARD=true
# Total retrieval latency budget (ms) used for the trace over-budget check.
EKRE_GOVERNANCE__TOTAL_LATENCY_BUDGET_MS=500.0
EKRE_GOVERNANCE__POLICY_VERSION=v1

# --- Deployment, scalability, resilience, and NFR validation ---
# Capability-grouped worker pool sizes.
EKRE_DEPLOYMENT__VECTOR_POOL_SIZE=4
EKRE_DEPLOYMENT__KEYWORD_POOL_SIZE=2
EKRE_DEPLOYMENT__METADATA_POOL_SIZE=2
EKRE_DEPLOYMENT__REPLICAS=2
# Circuit breaker: open after N consecutive failures, retry after reset seconds.
EKRE_DEPLOYMENT__CIRCUIT_BREAKER_THRESHOLD=5
EKRE_DEPLOYMENT__CIRCUIT_BREAKER_RESET_SECONDS=30.0
# Multi-tenant admission: max concurrent retrievals per tenant (0 = unlimited).
EKRE_DEPLOYMENT__TENANT_MAX_CONCURRENT=8
# NFR thresholds validated for EKCP handoff readiness.
EKRE_DEPLOYMENT__MAX_LATENCY_MS=500.0
EKRE_DEPLOYMENT__MIN_AVAILABILITY=0.999
EKRE_DEPLOYMENT__EVAL_K=10
EKRE_DEPLOYMENT__MIN_PRECISION_AT_K=0.5
EKRE_DEPLOYMENT__MIN_RECALL_AT_K=0.5
EKRE_DEPLOYMENT__MIN_MRR=0.5
EKRE_DEPLOYMENT__MIN_NDCG=0.5

